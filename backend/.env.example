# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=api.remoteworknaija.com,localhost,127.0.0.1

# Database (for future PostgreSQL migration)
DATABASE_URL=sqlite:///db.sqlite3

# CORS
CORS_ALLOWED_ORIGINS=https://remoteworknaija.com,https://www.remoteworknaija.com,http://localhost:3000

# Media & Static
MEDIA_URL=/media/
STATIC_URL=/static/

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
