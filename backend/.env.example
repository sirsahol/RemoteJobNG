# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (leave blank for SQLite, set for PostgreSQL)
# DATABASE_URL=postgres://user:password@localhost:5432/remoteworknaija

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Paystack (leave blank for mock mode in local dev)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FRONTEND_URL=http://localhost:3000

# Cloudinary (leave blank to use local file storage)
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Static & Media
STATIC_URL=/static/
MEDIA_URL=/media/
